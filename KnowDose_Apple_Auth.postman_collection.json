    {
      "name": "User Profile with JWT Header",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "url": {
          "raw": "http://localhost:4000/health",
          "protocol": "http",
          "host": ["localhost"],
          "port": "4000",
          "path": ["health"]
        },
        "description": "Example of using JWT token in Authorization header (req.userId will be available in middleware)"
      }
    }
